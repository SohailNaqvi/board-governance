{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": ["**/.env.local", ".env", ".env.*.local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:contract": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "typecheck": {
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
