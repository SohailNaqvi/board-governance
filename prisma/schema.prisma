// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Status Enums ============

enum AgendaItemStatus {
  DRAFT
  SUBMITTED
  VETTED
  APPROVED_FOR_AGENDA
  CIRCULATED
  DECIDED
  CLOSED
  RETURNED
  DEFERRED
  WITHDRAWN
}

enum WorkingPaperStatus {
  INSTANTIATED
  IN_AUTHORING
  IN_REVIEW
  FINALIZED
  CIRCULATED
  ARCHIVED
}

enum ActionTakenEntryStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  CLOSED
}

enum UserRole {
  AUTHORIZED_PROPOSER
  FEEDER_BODY_SECRETARY
  REGISTRAR
  TREASURER_LEGAL
  VICE_CHANCELLOR
  SYNDICATE_MEMBER
  SYSTEM_ADMINISTRATOR
  ASRB_CHAIR
  ASRB_SECRETARY
  ASRB_INTERNAL_MEMBER
  ASRB_EXTERNAL_MEMBER
  ASRB_COMPLIANCE_OFFICER
  ASRB_VETTING_OFFICER
  ASRB_NOTIFICATION_RECIPIENT
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  CALL_ISSUED
  SUBMISSIONS_OPEN
  SUBMISSIONS_CLOSED
  AGENDA_APPROVED
  PAPERS_CIRCULATED
  IN_SESSION
  CONCLUDED
  MINUTES_DRAFTED
  MINUTES_CONFIRMED
}

enum APCEEventStatus {
  PENDING
  TRIGGERED
  COMPLETED
  SKIPPED
}

// ============ Core Entities ============

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  role                UserRole
  passwordHash        String?
  mustChangePassword  Boolean   @default(true)
  deactivatedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([role])
}


model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeetingCalendar {
  id              String        @id @default(cuid())
  meetingNumber   Int           @unique
  title           String?
  meetingDate     DateTime
  meetingLocation String?
  status          MeetingStatus @default(DRAFT)
  onlineMeetingLink String?
  quorum          String?
  callNoticeAt    DateTime?
  cutoffAt        DateTime?
  vcApprovalDueAt DateTime?
  circulationAt   DateTime?
  queryCloseAt    DateTime?
  concludedAt     DateTime?
  minutesDraftDueAt DateTime?
  minutesConfirmAt  DateTime?
  createdBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  agendaItems      AgendaItem[]
  workingPapers    WorkingPaper[]
  resolutions      FeederBodyResolution[]
  decisions        Decision[]
  apceEvents       APCEEvent[]

  @@index([status])
  @@index([meetingDate])
}

model APCEEvent {
  id                String          @id @default(cuid())
  meetingCalendarId String
  eventCode         String
  eventName         String
  scheduledAt       DateTime
  triggeredAt       DateTime?
  status            APCEEventStatus @default(PENDING)
  offsetDays        Int
  description       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  meetingCalendar   MeetingCalendar @relation(fields: [meetingCalendarId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  notifications     InAppNotification[]

  @@unique([meetingCalendarId, eventCode])
  @@index([meetingCalendarId])
  @@index([eventCode])
  @@index([status])
  @@index([scheduledAt])
}

model InAppNotification {
  id            String    @id @default(cuid())
  recipientRole UserRole
  title         String
  message       String
  type          String    @default("info")
  read          Boolean   @default(false)
  readAt        DateTime?
  apceEventId   String?
  meetingCalendarId String?
  createdAt     DateTime  @default(now())

  apceEvent     APCEEvent? @relation(fields: [apceEventId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([recipientRole])
  @@index([read])
  @@index([createdAt])
  @@index([apceEventId])
}

model AgendaItem {
  id                String             @id @default(cuid())
  meetingCalendarId String
  itemNumber        Int
  title             String
  description       String?
  status            AgendaItemStatus   @default(DRAFT)
  proposedBy        String
  submittedDate     DateTime?
  vetted            Boolean            @default(false)
  vettedDate        DateTime?
  vetterNotes       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  meetingCalendar   MeetingCalendar    @relation(fields: [meetingCalendarId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workingPapers     WorkingPaper[]
  resolutions       FeederBodyResolution[]
  annexures         Annexure[]
  decisions         Decision[]

  @@unique([meetingCalendarId, itemNumber])
  @@index([meetingCalendarId])
  @@index([status])
  @@index([proposedBy])
}

model WorkingPaper {
  id              String               @id @default(cuid())
  meetingCalendarId String
  agendaItemId    String
  title           String
  content         String?
  status          WorkingPaperStatus   @default(INSTANTIATED)
  authoredBy      String
  reviewedBy      String?
  reviewComments  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  meetingCalendar MeetingCalendar      @relation(fields: [meetingCalendarId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  agendaItem      AgendaItem           @relation(fields: [agendaItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  annexures       Annexure[]
  readReceipts    ReadReceipt[]

  @@index([meetingCalendarId])
  @@index([agendaItemId])
  @@index([status])
  @@index([authoredBy])
}

model Annexure {
  id              String   @id @default(cuid())
  agendaItemId    String
  workingPaperId  String
  fileName        String
  fileType        String
  fileSize        Int
  fileUrl         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agendaItem      AgendaItem  @relation(fields: [agendaItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workingPaper    WorkingPaper @relation(fields: [workingPaperId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([agendaItemId])
  @@index([workingPaperId])
}

model FeederBodyResolution {
  id                String   @id @default(cuid())
  meetingCalendarId String
  agendaItemId      String
  bodyCode          String
  resolutionNumber  Int
  resolutionText    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  meetingCalendar   MeetingCalendar @relation(fields: [meetingCalendarId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  agendaItem        AgendaItem      @relation(fields: [agendaItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([bodyCode, resolutionNumber])
  @@index([meetingCalendarId])
  @@index([agendaItemId])
  @@index([bodyCode])
}

model SyndicateMember {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  memberNumber    String   @unique
  department      String?
  joinDate        DateTime
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  readReceipts    ReadReceipt[]
  memberQueries   MemberQuery[]

  @@index([status])
}

model ReadReceipt {
  id              String   @id @default(cuid())
  workingPaperId  String
  syndicateMemberId String
  readAt          DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workingPaper    WorkingPaper @relation(fields: [workingPaperId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  syndicateMember SyndicateMember @relation(fields: [syndicateMemberId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workingPaperId, syndicateMemberId])
  @@index([workingPaperId])
  @@index([syndicateMemberId])
}

model MemberQuery {
  id                String   @id @default(cuid())
  syndicateMemberId String
  queryText         String
  queryDate         DateTime @default(now())
  responseText      String?
  responseDate      DateTime?
  status            String   @default("OPEN")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  syndicateMember   SyndicateMember @relation(fields: [syndicateMemberId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([syndicateMemberId])
  @@index([status])
}

model Decision {
  id                String   @id @default(cuid())
  meetingCalendarId String
  agendaItemId      String
  decisionText      String
  decisionDate      DateTime
  decidedBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  meetingCalendar   MeetingCalendar @relation(fields: [meetingCalendarId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  agendaItem        AgendaItem      @relation(fields: [agendaItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actionTaken       ActionTakenEntry[]

  @@index([meetingCalendarId])
  @@index([agendaItemId])
  @@index([decidedBy])
}

model ActionTakenEntry {
  id                String                    @id @default(cuid())
  decisionId        String
  description       String
  assignedTo        String
  dueDate           DateTime
  status            ActionTakenEntryStatus    @default(OPEN)
  completedDate     DateTime?
  notes             String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  decision          Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  notificationForAction NotificationForAction[]

  @@index([decisionId])
  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
}

model NotificationForAction {
  id                    String   @id @default(cuid())
  actionTakenEntryId    String
  recipientEmail        String
  notificationDate      DateTime @default(now())
  acknowledgedDate      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  actionTakenEntry      ActionTakenEntry @relation(fields: [actionTakenEntryId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([actionTakenEntryId])
  @@index([recipientEmail])
}

model AuditEvent {
  id                String   @id @default(cuid())
  eventType         String
  entityType        String
  entityId          String
  userId            String
  changes           String   // JSON serialized
  payloadHash       String
  timestamp         DateTime @default(now())
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())

  @@index([eventType])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([timestamp])
}

// ============ ASRB Enums ============

enum ASRBCaseStatus {
  RECEIVED
  COMPLIANCE_EVALUATED
  VETTING
  READY_FOR_AGENDA
  ON_AGENDA
  DECIDED
  CLOSED
  RETURNED
  HELD
  WITHDRAWN
  URGENT_CIRCULATION
  DEFERRED
}

enum CaseType {
  SYNOPSIS_APPROVAL
  GEC_CONSTITUTION
  EXAMINER_APPOINTMENT
  RESULT_APPROVAL
  SUPERVISOR_CHANGE
  TOPIC_CHANGE
  EXTENSION_CANDIDATURE
  LEAVE_ABSENCE
  RESEARCH_PROJECT_APPROVAL
  COMPREHENSIVE_RESULT
  COURSEWORK_WAIVER
  OTHER
}

enum CaseUrgency {
  NORMAL
  URGENT_CIRCULATION
}

enum FeederBodyType {
  DGSC
  FACULTY_BOARD
}

enum ASRBMeetingStatus {
  SCHEDULED
  IN_SESSION
  CONCLUDED
  CANCELLED
}

enum ASRBMemberRoleType {
  CHAIR
  INTERNAL
  EXTERNAL
  SECRETARY
}

enum ComplianceEvaluationStatus {
  IN_PROGRESS
  COMPLETE
}

// ============ ASRB Core Entities ============

model ASRBCase {
  id                    String          @id @default(cuid())
  caseType              CaseType
  status                ASRBCaseStatus  @default(RECEIVED)
  urgency               CaseUrgency     @default(NORMAL)
  receiptReference      String          @unique
  idempotencyKey        String
  feederClientId        String
  feederBodyType        FeederBodyType
  feederBodyCode        String
  feederResolutionBody  String?
  feederResolutionNum   String?
  feederResolutionDate  DateTime?
  studentRegNo          String?
  supervisorEmpId       String?
  programmeCode         String?
  casePayload           String          // JSON
  receivedAt            DateTime        @default(now())
  lastTransitionAt      DateTime        @default(now())
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  attachments           CaseAttachment[]
  auditEvents           CaseAuditEvent[]
  complianceEvaluations ComplianceEvaluation[]
  feederClient          FeederClient    @relation(fields: [feederClientId], references: [id])

  @@unique([feederClientId, idempotencyKey])
  @@index([status])
  @@index([caseType])
  @@index([feederClientId])
  @@index([receiptReference])
}

model CaseAttachment {
  id            String   @id @default(cuid())
  caseId        String
  filename      String
  mimeType      String
  sizeBytes     Int
  docType       String
  storageRef    String?
  uploadToken   String?  @unique
  uploadExpiry  DateTime?
  uploaded      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  case          ASRBCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([uploadToken])
}

model CaseAuditEvent {
  id          String   @id @default(cuid())
  caseId      String
  eventType   String
  actorId     String
  payloadHash String
  details     String?  // JSON
  occurredAt  DateTime @default(now())

  case        ASRBCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([eventType])
}

model FeederClient {
  id                  String         @id @default(cuid())
  displayName         String
  feederBodyType      FeederBodyType
  feederBodyCode      String         @unique
  apiKeyHash          String
  permittedCaseTypes  String         // JSON array of CaseType
  active              Boolean        @default(true)
  rateLimitOverride   Int?
  lastUsedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  cases               ASRBCase[]

  @@index([apiKeyHash])
  @@index([feederBodyCode])
}

enum RuleSource {
  HEC
  UNIVERSITY
  FACULTY
  PROGRAMME
}

enum RuleSeverity {
  BLOCKING
  WARNING
  INFORMATIONAL
}

enum RuleOutcome {
  PASS
  FAIL
  WARN
  NOT_APPLICABLE
  ERROR
}

enum ComplianceStatus {
  COMPLIANT
  NEEDS_REVIEW
  NON_COMPLIANT
}

// ============ Compliance Entities ============

model ComplianceRule {
  id                        String       @id @default(cuid())
  ruleId                    String       // Stable identifier across versions, e.g. HEC_PHD_SUPERVISOR_QUALIFICATION
  source                    RuleSource
  sourceReference           String?      // Citation, e.g. "HEC PhD Policy 2023, Section 4.2"
  appliesToCaseTypes        String       // JSON array of CaseType values
  appliesToProgrammeTypes   String?      // JSON array of programme type codes
  severity                  RuleSeverity
  evaluation                String       // JSON predicate expression
  messageTemplate           String       // Human-readable with placeholders
  effectiveFrom             DateTime?
  effectiveTo               DateTime?
  version                   Int          @default(1)
  status                    String       @default("DRAFT") // DRAFT, EFFECTIVE, RETIRED
  lastEditedBy              String?
  lastEditedAt              DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  ruleEvaluations           RuleEvaluation[]

  @@unique([ruleId, version])
  @@index([ruleId])
  @@index([source])
  @@index([status])
  @@index([effectiveFrom])
  @@index([effectiveTo])
}

model ComplianceEvaluation {
  id                String           @id @default(cuid())
  caseId            String
  status            ComplianceStatus
  evaluatedAt       DateTime         @default(now())
  rulesVersionSet   String           // JSON: snapshot of rule versions used
  summary           String?          // JSON: aggregate summary
  createdAt         DateTime         @default(now())

  case              ASRBCase         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ruleEvaluations   RuleEvaluation[]

  @@index([caseId])
  @@index([status])
  @@index([evaluatedAt])
}

model RuleEvaluation {
  id               String              @id @default(cuid())
  evaluationId     String
  ruleId           String              // Matches ComplianceRule.ruleId
  ruleVersion      Int
  complianceRuleId String?             // FK to the specific ComplianceRule record
  outcome          RuleOutcome
  evidence         String?             // JSON: observed values
  message          String?             // Rendered message
  createdAt        DateTime            @default(now())

  evaluation       ComplianceEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  complianceRule   ComplianceRule?      @relation(fields: [complianceRuleId], references: [id])

  @@index([evaluationId])
  @@index([ruleId])
  @@index([outcome])
  @@index([complianceRuleId])
}

// ============ ASRB Meeting & Member Entities ============

model ASRBMeeting {
  id              String             @id @default(cuid())
  meetingNumber   Int                @unique
  scheduledAt     DateTime
  status          ASRBMeetingStatus  @default(SCHEDULED)
  cycleCode       String?
  concludedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([cycleCode])
}

model ASRBMember {
  id          String              @id @default(cuid())
  fullName    String
  designation String
  roleType    ASRBMemberRoleType
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([roleType])
  @@index([active])
}

/// app_data table belongs to must-odoo-hr-tracker (MUST faculty reporting).
/// This database is shared between projects. board-governance does NOT
/// read or write this table. The model exists only so that prisma db push
/// does not propose to drop the table.
model app_data {
  id         Int      @id @default(1)
  data       Json
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@ignore
}
